rules_version = '2';

/**
 * Mortar — Firestore security (dev / stage / prod)
 *
 * Deploy: `firebase use staging` (or dev) then `firebase deploy --only firestore:rules`
 *
 * Design notes:
 * - Cloud Functions use Admin SDK and bypass these rules.
 * - Custom claims: assign `roles` array via Admin SDK (e.g. "Admin", "superAdmin").
 * - invite_codes: unauthenticated read is required for the current web /join flow
 *   (query by code before sign-up). This cannot fully prevent enumeration of unused
 *   invites via crafted queries; migrate validation to a callable for stronger security.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function tokenRoles() {
      return ('roles' in request.auth.token && request.auth.token.roles is list)
        ? request.auth.token.roles
        : [];
    }

    /** Admin panel + privileged operations */
    function hasStaffClaim() {
      return isSignedIn()
        && tokenRoles() is list
        && tokenRoles().hasAny(['Admin', 'superAdmin']);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** True if document data grants network admin (Firestore mirror of claims). */
    function dataHasStaffRole(data) {
      return (data.keys().hasAll(['roles'])
          && data.roles is list
          && data.roles.hasAny(['Admin', 'superAdmin']))
        || data.get('role', '') == 'Admin'
        || data.get('role', '') == 'superAdmin';
    }

    /** Block users from granting themselves Admin/superAdmin via client writes. */
    function gainedPrivilegedUserFields() {
      return !dataHasStaffRole(resource.data) && dataHasStaffRole(request.resource.data);
    }

    // --- Expansion roster (server-maintained; admin UI reads) ---
    match /eligibleUsers/{emailDoc} {
      allow read: if hasStaffClaim();
      allow write: if false;
    }

    match /inviteCodes/{inviteId} {
      allow read: if hasStaffClaim();
      allow write: if false;
    }

    match /expansion_cohort_emails/{docId} {
      allow read, write: if hasStaffClaim();
    }

    // --- User profiles ---
    /** Owner cannot self-grant staff, tamper with server counters, or forge earned badges. */
    function userBadgesEarnedUnchanged() {
      let beforeEarned = resource.data.get('badges', {}).get('earned', []);
      let afterEarned = request.resource.data.get('badges', {}).get('earned', []);
      return beforeEarned == afterEarned;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && !dataHasStaffRole(request.resource.data)
        || hasStaffClaim();
      allow update: if hasStaffClaim()
        || (isOwner(userId) && !gainedPrivilegedUserFields()
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['gamification'])
          && userBadgesEarnedUnchanged());
      allow delete: if hasStaffClaim();
    }

    match /users/{userId}/certificates/{certId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/notifications/{notifId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/surveyResponses/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/saved_group_threads/{docId} {
      allow read, write: if isOwner(userId);
    }

    // --- Web join (legacy); see file header ---
    match /invite_codes/{docId} {
      allow read: if true;
      allow create, delete: if hasStaffClaim();
      allow update: if isSignedIn()
        && resource.data.used == false
        && request.resource.data.used == true
        && request.resource.data.used_by == request.auth.uid;
    }

    // --- Community feed (Expansion app + curriculum) ---
    match /feed_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.author_id == request.auth.uid;
    }

    match /feed_posts/{postId}/likes/{likerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == likerId;
    }

    match /feed_posts/{postId}/replies/{replyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.author_id == request.auth.uid;
    }

    match /feed_posts/{postId}/replies/{replyId}/likes/{likerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == likerId;
    }

    // --- Events (RSVP from mobile + curriculum admin) ---
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, delete: if hasStaffClaim();
      // Admins edit full documents; members may only touch RSVP-related fields.
      allow update: if hasStaffClaim()
        || (isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['registered_users', 'updated_at', 'available_spots']));
    }

    // --- Curriculum structure ---
    match /curricula/{document=**} {
      allow read: if isSignedIn();
      allow write: if hasStaffClaim();
    }

    match /courses/{document=**} {
      allow read: if isSignedIn();
      allow write: if hasStaffClaim();
    }

    match /courseProgress/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // --- Groups (member changes via joinGroup / leaveGroup callables only) ---
    match /Groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if hasStaffClaim();
      allow update: if hasStaffClaim();
      allow delete: if hasStaffClaim();
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/Groups/$(groupId));
    }

    function isGroupMember(groupId) {
      return groupDoc(groupId).exists
        && groupDoc(groupId).data.keys().hasAll(['GroupMembers'])
        && groupDoc(groupId).data.GroupMembers is list
        && request.auth.uid in groupDoc(groupId).data.GroupMembers;
    }

    match /Groups/{groupId}/Messages/{msgId} {
      allow read: if isSignedIn() && (hasStaffClaim() || isGroupMember(groupId));
      allow create: if isSignedIn()
        && request.resource.data.Senderid == request.auth.uid
        && (hasStaffClaim() || isGroupMember(groupId));
      allow update, delete: if hasStaffClaim();
    }

    function groupThreadAuthorUpdateKeys() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['body', 'title', 'updated_at']);
    }

    match /Groups/{groupId}/threads/{threadId} {
      allow read: if isSignedIn() && (hasStaffClaim() || isGroupMember(groupId));
      allow create: if isSignedIn() && isGroupMember(groupId)
        && request.resource.data.author_id == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 20000
        && request.resource.data.author_name is string;
      allow update: if hasStaffClaim()
        || (isSignedIn() && isGroupMember(groupId)
          && resource.data.author_id == request.auth.uid
          && groupThreadAuthorUpdateKeys());
      allow delete: if hasStaffClaim()
        || (isSignedIn() && isGroupMember(groupId)
          && resource.data.author_id == request.auth.uid);
    }

    match /Groups/{groupId}/threads/{threadId}/comments/{commentId} {
      allow read: if isSignedIn() && (hasStaffClaim() || isGroupMember(groupId));
      allow create: if isSignedIn() && isGroupMember(groupId)
        && request.resource.data.author_id == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 10000
        && request.resource.data.author_name is string;
      allow update: if hasStaffClaim()
        || (isSignedIn() && isGroupMember(groupId)
          && resource.data.author_id == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['body', 'updated_at']));
      allow delete: if hasStaffClaim()
        || (isSignedIn() && isGroupMember(groupId)
          && resource.data.author_id == request.auth.uid);
    }

    function voteValueOk() {
      return request.resource.data.keys().hasOnly(['value', 'updated_at'])
        && request.resource.data.value is int
        && (request.resource.data.value == 1 || request.resource.data.value == -1);
    }

    match /Groups/{groupId}/threads/{threadId}/votes/{voterId} {
      allow read: if isSignedIn() && (hasStaffClaim() || isGroupMember(groupId));
      allow create, update: if isSignedIn() && isGroupMember(groupId)
        && request.auth.uid == voterId
        && voteValueOk();
      allow delete: if isSignedIn() && isGroupMember(groupId) && request.auth.uid == voterId;
    }

    match /Groups/{groupId}/threads/{threadId}/comments/{commentId}/votes/{voterId} {
      allow read: if isSignedIn() && (hasStaffClaim() || isGroupMember(groupId));
      allow create, update: if isSignedIn() && isGroupMember(groupId)
        && request.auth.uid == voterId
        && voteValueOk();
      allow delete: if isSignedIn() && isGroupMember(groupId) && request.auth.uid == voterId;
    }

    // --- Mobile-only groups (Expansion app); threads mirror `Groups` ---
    function mobileGroupDoc(groupId) {
      return get(/databases/$(database)/documents/groups_mobile/$(groupId));
    }

    function isMobileGroupMember(groupId) {
      return mobileGroupDoc(groupId).exists
        && mobileGroupDoc(groupId).data.keys().hasAll(['GroupMembers'])
        && mobileGroupDoc(groupId).data.GroupMembers is list
        && request.auth.uid in mobileGroupDoc(groupId).data.GroupMembers;
    }

    /** Optional `category` on `groups_mobile` — must match app allowlist when present. */
    function mobileGroupCategoryOk() {
      return !request.resource.data.keys().hasAny(['category'])
        || (request.resource.data.category is string
          && (request.resource.data.category == ''
            || request.resource.data.category in [
              'Business & Entrepreneurship',
              'Marketing & Brand Growth',
              'Money, Funding & Resources',
              'Operations & Logistics',
              'Community & Networking',
              'Events & Opportunities',
              'Industry-Specific',
              'Wins, Lessons & Advice'
            ]));
    }

    match /groups_mobile/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.Name is string
        && request.resource.data.Name.size() > 0
        && request.resource.data.Name.size() <= 120
        && request.resource.data.Status in ['Open', 'Closed']
        && request.resource.data.GroupMembers is list
        && request.auth.uid in request.resource.data.GroupMembers
        && request.resource.data.PendingMembers is list
        && request.resource.data.createdBy == request.auth.uid
        && !request.resource.data.keys().hasAny(['isFeatured', 'featuredRank'])
        && (!('memberCount' in request.resource.data) || request.resource.data.memberCount == 1)
        && (!('threadCount' in request.resource.data) || request.resource.data.threadCount == 0)
        && mobileGroupCategoryOk();
      allow update: if mobileGroupCategoryOk()
        && (hasStaffClaim()
        || (isSignedIn() && resource.data.get('createdBy', '') == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'GroupMembers', 'PendingMembers', 'memberCount', 'threadCount', 'isFeatured', 'featuredRank'
          ])));
      allow delete: if hasStaffClaim()
        || (isSignedIn() && resource.data.get('createdBy', '') == request.auth.uid);
    }

    match /groups_mobile/{groupId}/threads/{threadId} {
      allow read: if isSignedIn() && (hasStaffClaim() || isMobileGroupMember(groupId));
      allow create: if isSignedIn() && isMobileGroupMember(groupId)
        && request.resource.data.author_id == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 20000
        && request.resource.data.author_name is string;
      allow update: if hasStaffClaim()
        || (isSignedIn() && isMobileGroupMember(groupId)
          && resource.data.author_id == request.auth.uid
          && groupThreadAuthorUpdateKeys());
      allow delete: if hasStaffClaim()
        || (isSignedIn() && isMobileGroupMember(groupId)
          && resource.data.author_id == request.auth.uid);
    }

    match /groups_mobile/{groupId}/threads/{threadId}/comments/{commentId} {
      allow read: if isSignedIn() && (hasStaffClaim() || isMobileGroupMember(groupId));
      allow create: if isSignedIn() && isMobileGroupMember(groupId)
        && request.resource.data.author_id == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 10000
        && request.resource.data.author_name is string;
      allow update: if hasStaffClaim()
        || (isSignedIn() && isMobileGroupMember(groupId)
          && resource.data.author_id == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['body', 'updated_at']));
      allow delete: if hasStaffClaim()
        || (isSignedIn() && isMobileGroupMember(groupId)
          && resource.data.author_id == request.auth.uid);
    }

    match /groups_mobile/{groupId}/threads/{threadId}/votes/{voterId} {
      allow read: if isSignedIn() && (hasStaffClaim() || isMobileGroupMember(groupId));
      allow create, update: if isSignedIn() && isMobileGroupMember(groupId)
        && request.auth.uid == voterId
        && voteValueOk();
      allow delete: if isSignedIn() && isMobileGroupMember(groupId) && request.auth.uid == voterId;
    }

    match /groups_mobile/{groupId}/threads/{threadId}/comments/{commentId}/votes/{voterId} {
      allow read: if isSignedIn() && (hasStaffClaim() || isMobileGroupMember(groupId));
      allow create, update: if isSignedIn() && isMobileGroupMember(groupId)
        && request.auth.uid == voterId
        && voteValueOk();
      allow delete: if isSignedIn() && isMobileGroupMember(groupId) && request.auth.uid == voterId;
    }

    match /badge_definitions/{badgeId} {
      allow read: if isSignedIn();
      allow write: if hasStaffClaim();
    }

    match /achievement_events/{eventId} {
      allow read: if hasStaffClaim();
      allow write: if false;
    }

    // --- DMs (student thread + admin replies). Collection id contains spaces — URL-encode in rules paths. ---
    match /Digital%20Student%20DMs/{dmId} {
      allow read: if isSignedIn()
        && (resource.data.uid == request.auth.uid || hasStaffClaim());
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if hasStaffClaim();
    }

    match /Digital%20Student%20DMs/{dmId}/replies/{replyId} {
      allow read: if isSignedIn()
        && (get(/databases/$(database)/documents/Digital%20Student%20DMs/$(dmId)).data.uid == request.auth.uid
          || hasStaffClaim());
      allow create, update, delete: if hasStaffClaim();
    }

    // --- Graduation applications ---
    match /GraduationApplications/{appId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || hasStaffClaim());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if hasStaffClaim();
    }

    // --- Shop catalog (browse may be unauthenticated; stock updates from signed-in shoppers) ---
    match /shopItems/{itemId} {
      allow read: if true;
      allow create, delete: if hasStaffClaim();
      allow update: if hasStaffClaim()
        || (isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['sizeStocks', 'stockQuantity', 'updatedAt']));
    }

    // --- Web dashboard collections (tighten further when author fields are stable) ---
    match /discussion_threads/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if hasStaffClaim();
    }

    match /meeting_proposals/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if hasStaffClaim();
    }

    match /certificates/{docId} {
      allow read: if isSignedIn();
      allow write: if hasStaffClaim();
    }

    // --- Deny everything else ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
