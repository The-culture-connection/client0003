rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.roles != null && role in request.auth.token.roles;
    }
    
    function hasAnyRole(roles) {
      return isAuthenticated() && request.auth.token.roles != null && 
             request.auth.token.roles.hasAny(roles);
    }
    
    function isSuperAdmin() {
      return hasRole('superAdmin');
    }
    
    function isContentAdmin() {
      return hasRole('contentAdmin');
    }
    
    function isEventAdmin() {
      return hasRole('eventAdmin');
    }
    
    function isModerator() {
      return hasRole('moderator');
    }
    
    function isAnalyst() {
      return hasRole('analyst');
    }
    
    // Deny by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Users collection - users can read their own, admins can read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin() || isContentAdmin() || isEventAdmin();
      allow write: if false; // Only Functions can write
    }
    
    // Data rooms - users can read their own, admins can read all
    match /data_rooms/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin() || isContentAdmin() || isEventAdmin();
      allow write: if false; // Only Functions can write
    }
    
    // User progress - users can read their own, admins can read all
    match /user_progress/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin() || isContentAdmin() || isEventAdmin() || isAnalyst();
      allow write: if false; // Only Functions can write (for progress/scoring)
    }
    
    // Analytics events - read only for admins/analysts, no client writes
    match /analytics_events/{eventId} {
      allow read: if isSuperAdmin() || isAnalyst();
      allow write: if false; // Only Functions can write
    }
    
    // Badges - users can read their own, admins can read all
    match /badges/{badgeId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Functions can write
    }
    
    // Certificates - users can read their own, admins can read all
    match /certificates/{certId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Functions can write
    }
    
    // Approvals - admins can read/write, users can read their own
    match /approvals/{approvalId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Functions can write
    }
    
    // Content collections - read for authenticated, write only via Functions
    match /content/{contentId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Functions can write
    }
    
    // Events - read for authenticated, write only via Functions
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Functions can write
    }
  }
}
