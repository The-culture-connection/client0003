rules_version='2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
             request.auth.token.roles != null && 
             role in request.auth.token.roles;
    }
    
    function isAdmin() {
      return hasRole('Admin');
    }
    
    function hasPermission(permission) {
      return isAdmin() || 
             (isAuthenticated() && 
              request.auth.token.permissions != null && 
              permission in request.auth.token.permissions);
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow users to create their own document if it doesn't exist (for onboarding)
      allow create: if isOwner(userId) && 
                      request.resource.data.uid == userId &&
                      request.resource.data.email == request.auth.token.email;
      // Allow users to update their own onboarding_status and roles during onboarding
      allow update: if isOwner(userId) && 
                      // Ensure critical fields are not changed (if they exist)
                      (!('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid) &&
                      (!('email' in request.resource.data) || request.resource.data.email == resource.data.email);
      // Delete must go through Functions
      allow delete: if false;
    }
    
    // Curriculum content (read-only for authenticated users)
    match /curricula/{curriculumId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
        
        match /chapters/{chapterId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin();
          
          match /lessons/{lessonId} {
            allow read: if isAuthenticated();
            allow write: if isAdmin();
          }
        }
      }
    }
    
    // Quizzes (read-only for authenticated users)
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /variants/{variantId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
        
        match /questions/{questionId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin();
        }
      }
    }
    
    // Quiz attempts (read own, write via Functions only)
    match /quiz_attempts/{attemptId} {
      allow read: if isOwner(resource.data.user_id) || isAdmin();
      allow write: if false; // Only via Functions
    }
    
    // User progress (read own, write via Functions only)
    match /user_progress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Only via Functions
      
      match /lesson_progress/{lessonId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
      
      match /chapter_results/{chapterId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
      
      match /module_results/{moduleId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
      
      match /curriculum_results/{curriculumId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
    }
    
    // Data rooms (read own, write via Functions only)
    match /data_rooms/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Only via Functions
      
      match /documents/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Only via Functions
      }
    }
    
    // Document templates (read for authenticated, write admin)
    match /document_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Module asset requirements (read for authenticated, write admin)
    match /module_asset_requirements/{moduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /requirements/{reqId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }
    
    // Certificates (read own, write via Functions only)
    match /certificates/{certId} {
      allow read: if isOwner(resource.data.user_id) || isAdmin();
      allow write: if false; // Only via Functions
    }
    
    // Badges (read own, write via Functions only)
    match /badges/{badgeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Events (read authenticated, write admin or with permission)
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || hasPermission('event_posting');
      
      match /rsvps/{userId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }
    
    // Discussion threads (read authenticated, write authenticated)
    match /discussion_threads/{threadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('post_posting');
      allow update, delete: if isOwner(resource.data.author_id) || isAdmin();
      
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isOwner(resource.data.author_id) || isAdmin();
      }
    }
    
    // Meeting proposals (read authenticated, write authenticated)
    match /meeting_proposals/{proposalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.proposer_id) || isAdmin();
      allow delete: if isOwner(resource.data.proposer_id) || isAdmin();
    }
    
    // Analytics events (read admin only, write via Functions only)
    match /analytics_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // Only via Functions
    }
    
    // Points ledger (read own, write via Functions only)
    match /points_ledger/{entryId} {
      allow read: if isOwner(resource.data.user_id) || isAdmin();
      allow write: if false; // Only via Functions
    }
    
    // Match profiles (read own, write via Functions only)
    match /match_profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Only via Functions
    }

    // Taxonomies (read for authenticated, write admin only)
    match /taxonomies/{taxonomyType} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // Matches (read own suggestions, write via Functions only)
    match /matches/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Only via Functions

      match /suggestions/{suggestionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Only via Functions
      }
    }

    // Jobs (read authenticated, write with permission)
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || hasPermission("job_posting");
    }

    // Skill ads (read authenticated, write with permission)
    match /skill_ads/{adId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || hasPermission("skill_posting");
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
