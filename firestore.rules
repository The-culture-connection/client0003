rules_version='2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Open access for development. Expires automatically — extend before then
      // or replace with production rules. (2026-03-27 was already past on 2026-04-03.)
      allow read, write: if request.time < timestamp.date(2026, 12, 31);
    }
  }
}
