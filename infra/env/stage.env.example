# Firebase Stage Environment Variables
# Copy this file to .env and fill in the values

# Firebase Project Configuration
FIREBASE_PROJECT_ID=mortar-stage
FIREBASE_AUTH_DOMAIN=mortar-stage.firebaseapp.com
FIREBASE_STORAGE_BUCKET=mortar-stage.firebasestorage.app

# Web App Configuration
NEXT_PUBLIC_FIREBASE_ENV=stage
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mortar-stage
NEXT_PUBLIC_USE_EMULATOR=false

# Functions Configuration
FUNCTIONS_REGION=us-central1
