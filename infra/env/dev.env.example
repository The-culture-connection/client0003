# Firebase Dev Environment Variables
# Copy this file to .env and fill in the values

# Firebase Project Configuration
FIREBASE_PROJECT_ID=mortar-dev
FIREBASE_AUTH_DOMAIN=mortar-dev.firebaseapp.com
FIREBASE_STORAGE_BUCKET=mortar-dev.firebasestorage.app

# Web App Configuration
NEXT_PUBLIC_FIREBASE_ENV=dev
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mortar-dev
NEXT_PUBLIC_USE_EMULATOR=true

# Functions Configuration
FUNCTIONS_REGION=us-central1

# Emulator Configuration
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8085
FIREBASE_FUNCTIONS_EMULATOR_HOST=localhost:5001
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
