# Staging Firebase for the Vite app (same vars as Railway → Service → Variables).
#
# Local: copy this file to `.env.local` in this folder (`Digital Curriculum/`).
# Vite loads `.env.local` for every `npm run dev` and `npm run build`.
# (`.env.stage` only applies if you run `vite --mode stage`; default build uses production mode.)
#
# `.env.local` is gitignored at the repo root — do not commit secrets here.
VITE_FIREBASE_ENV=stage

# Optional overrides (defaults come from firebase.ts `stage` block when env is stage)
# VITE_USE_EMULATOR=false
# VITE_FUNCTIONS_URL=
