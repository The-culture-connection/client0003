rules_version = '2';

/**
 * Mortar — Cloud Storage (production-oriented)
 * Deploy: `firebase use <alias>` then `firebase deploy --only storage`
 *
 * For permissive dev/test rules, see `storage.rules.testing` and point
 * firebase.json "storage.rules" at that file only on non-prod projects.
 */

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function tokenRoles() {
      return ('roles' in request.auth.token && request.auth.token.roles is list)
        ? request.auth.token.roles
        : [];
    }

    function hasStaffClaim() {
      return isSignedIn() && tokenRoles().hasAny(['Admin', 'superAdmin']);
    }

    function isSuperAdmin() {
      return isSignedIn() && tokenRoles().hasAny(['superAdmin']);
    }

    // Published lesson slide assets (curriculum player)
    match /lesson_assets/{curriculumId}/{moduleId}/{chapterId}/{lessonId}/{slideId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Legacy course file layout
    match /courses/{courseId}/modules/{moduleId}/lessons/{lessonId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if hasStaffClaim();
    }

    // Shop product images (public catalog)
    match /shop/{fileName} {
      allow read: if true;
      allow write: if hasStaffClaim();
    }

    // Admin-created events (feed / curriculum)
    match /events/images/{fileName} {
      allow read: if true;
      allow write: if hasStaffClaim();
    }

    // Member-submitted event flyers (Expansion app); path scoped by uid
    match /events/member_uploads/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 11 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Staff Mortar Info announcements (images + videos; postId from Firestore doc id)
    match /mortar_info/{postId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if hasStaffClaim()
        && request.resource.size < 101 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*'));
    }

    // Community feed post images (Expansion app); path scoped by uid
    match /feed_posts/member_uploads/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 11 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Badge bank — staff uploads for achievement art (referenced by `badge_definitions.image_url`)
    match /badge_bank/{fileName} {
      allow read: if true;
      allow write: if hasStaffClaim()
        && request.resource.size < 6 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Course builder uploads (lesson images, etc.)
    match /curriculum_content/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if hasStaffClaim();
    }

    // PPTX import staging files
    match /curriculum_imports/{allPaths=**} {
      allow read: if hasStaffClaim();
      allow write: if hasStaffClaim();
    }

    // Data room PDFs and user-generated uploads
    match /users/{userId}/dataroom/{allPaths=**} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Profile photo + business logo (Expansion onboarding / profile)
    match /users/{userId}/profile/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 11 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
