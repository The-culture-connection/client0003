{
  "name": "mortar-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "web",
    "functions"
  ],
  "scripts": {
    "emulators": "firebase emulators:start",
    "emulators:export": "firebase emulators:export ./emulator-data",
    "emulators:import": "firebase emulators:start --import=./emulator-data",
    "deploy:stage": "firebase deploy --project mortar-stage --only functions,firestore:rules,firestore:indexes,storage",
    "deploy:stage:rules": "firebase deploy --project mortar-stage --only firestore:rules,storage",
    "deploy:stage:functions": "firebase deploy --project mortar-stage --only functions",
    "seed": "node infra/scripts/seed.js",
    "seed:dev:expansion-mock": "npm --prefix infra/scripts run seed:dev:expansion-mock",
    "seed:stage:expansion-mock": "npm --prefix infra/scripts run seed:stage:expansion-mock",
    "assign-superadmin": "node infra/scripts/assign-superadmin-roles.js",
    "lint": "npm run lint --workspaces",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:analytics:unit": "npm --prefix functions run test:analytics:unit",
    "test:analytics:integration": "firebase emulators:exec --only functions,auth,firestore --project mortar-dev \"node ./functions/scripts/analytics-callable-integration.mjs\"",
    "test:analytics:phase5": "firebase emulators:exec --only functions,auth,firestore --project mortar-dev \"node ./functions/scripts/phase5-emulator-check.mjs\"",
    "test:analytics": "npm run test:analytics:unit && npm run test:analytics:integration"
  },
  "devDependencies": {
    "firebase-tools": "^13.0.0",
    "firebase-admin": "^13.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
